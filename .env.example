# ============================================================
# INSURANCE POLICY SERVICE - ENVIRONMENT VARIABLES TEMPLATE
# ============================================================
# INSTRUCCIONES:
# 1. Copiar este archivo como .env
# 2. Reemplazar los valores de ejemplo con valores reales
# 3. NUNCA commitear .env con datos sensibles

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
SPRING_DATASOURCE_URL=jdbc:h2:mem:insurance_db
SPRING_DATASOURCE_DRIVERCLASSNAME=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

SPRING_H2_CONSOLE_ENABLED=true

# ============================================================
# JPA/HIBERNATE CONFIGURATION
# ============================================================
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.H2Dialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOWSQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# ============================================================
# SECURITY - JWT TOKEN
# ============================================================
# CRITICAL: Cambiar en producción - Mínimo 256 caracteres
JWT_SECRET=your-super-secret-key-change-in-production-minimum-256-bits-required
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ============================================================
# SECURITY - CORS & HEADERS
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_MAX_AGE=3600

# ============================================================
# SERVER CONFIGURATION
# ============================================================
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api/v1
SERVER_SSL_ENABLED=false
SERVER_SSL_KEYSTORE=
SERVER_SSL_KEYSTORE_PASSWORD=

# ============================================================
# LOGGING
# ============================================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_INSURANCE=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=INFO
LOGGING_FILE=logs/insurance-policy-service.log

# ============================================================
# ACTUATOR
# ============================================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized

# ============================================================
# APPLICATION INFO
# ============================================================
SPRING_APPLICATION_NAME=Insurance Policy Service
APP_VERSION=1.0.0
APP_DESCRIPTION=Backend para gestión de clientes y pólizas de seguros
